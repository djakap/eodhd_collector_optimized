# Environment variables template for EODHD Collector
# Copy this file to .env and fill in your values

# EODHD API Configuration
EODHD_API_KEY=6976bf4be7ab42.10938432
EODHD_PLAN=all_world_extended

# QuestDB Configuration (Same instance as existing project)
QUESTDB_HOST=localhost
QUESTDB_HTTP_PORT=9000
QUESTDB_PG_PORT=8812
QUESTDB_INFLUX_PORT=9009
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_DATABASE=qdb

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/eodhd_collector.log

# Collection Settings
BATCH_SIZE=10
REQUEST_DELAY=0.1
MAX_RETRIES=3
